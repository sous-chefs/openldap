#####
#
# This is a slapd.conf file. See slapd.conf(5) for more info.
#
# Generated by Chef. Do not hand edit
#
####

# TLS configuration
<% if @config[:tls_enabled] || @config[:ldaps_enabled] -%>
TLSCertificateFile     <%= @config[:tls_cert] %>
TLSCertificateKeyFile  <%= @config[:tls_key] %>
<% if @config[:tls_cafile] -%>
TLSCACertificateFile   <%= @config[:tls_cafile] %>
<% end -%>
<% if @config[:tls_ciphersuite] -%>
TLSCipherSuite         <%= @config[:tls_ciphersuite] %>
<% end -%>
<% end -%>

# Schema and objectClass definitions
<% @config[:schemas].sort.each do |schema| -%>
include         <%= @paths[:dir] %>/schema/<%= schema %>
<% end -%>

pidfile         <%= @paths[:run_dir] %>/slapd.pid
argsfile        <%= @paths[:run_dir] %>/slapd.args
loglevel        <%= @config[:loglevel] %>

modulepath       <%= @paths[:module_dir] %>
<% @config[:modules].sort.each do |mod| -%>
moduleload       <%= mod %>
<% end -%>
<% if @config[:slapd_type] == 'provider' -%>
moduleload       syncprov
<% end -%>

tool-threads     1

backend		<%= @config[:database] %>
database        <%= @config[:database] %>
suffix          "<%= @config[:basedn] %>"
rootdn          "cn=<%= @config[:cn] %>,<%= @config[:basedn] %>"
rootpw          <%= @config[:rootpw] %>
directory       "<%= @paths[:db_dir] %>"
lastmod         on

<% if @config[:database] == 'hdb' -%>
dbconfig set_cachesize <%= @config[:dbconfig]['set_cachesize'] %>
dbconfig set_lk_max_objects <%= @config[:dbconfig]['set_lk_max_objects'] %>
dbconfig set_lk_max_locks <%= @config[:dbconfig]['set_lk_max_locks'] %>
dbconfig set_lk_max_lockers <%= @config[:dbconfig]['set_lk_max_lockers'] %>
<% end -%>

<% @config[:indexes].each do |value| -%>
index <%= value %>
<% end -%>

<% if @config[:slapd_type] == 'provider' -%>
<% @config[:syncrepl_provider_config].each do |key, value| -%>
<%= key %> <%= value %>
<% end -%>
<% end -%>
<% if @config[:slapd_type] == 'consumer' -%>
syncrepl rid=<%= @config[:slapd_rid] %>
<% if @config[:slapd_provider] -%>
  provider=<%= @config[:syncrepl_uri] %>://<%= @config[:slapd_provider] %>:<%= @config[:syncrepl_port] %>
<% else -%>
  provider=<%= @config[:syncrepl_uri] %>://<%= @config[:server] %>:<%= @config[:syncrepl_port] %>
<% end -%>
<% @config[:syncrepl_consumer_config].each do |key, value| -%>
  <%= key %>=<%= value %>
<% end -%>
<% end -%>

<% @config[:server_config_hash].each do |key, value| -%>
<%   case value -%>
<%   when nil -%>
<%= key %>
<%   when Array -%>
<%= key %>
<%     value.each do |v| -%>
  <%= v %>
<%     end -%>
<%   when String, Integer -%>
<%= key %> <%= value %>
<%   end -%>
<% end -%>

access to attrs=<%= @config[:user_attrs] %>
        by group.exact="cn=<%= @config[:admin_cn] %>,<%= @config[:basedn] %>" write
<% if @config[:slapd_type] == 'provider' -%>
        by dn="<%= @config[:syncrepl_cn] %>,<%= @config[:basedn] %>" read
<% end -%>
        by anonymous auth
        by self write
        by * none

access to dn.base="" by * read

access to *
        by group.exact="cn=<%= @config[:admin_cn] %>,<%= @config[:basedn] %>" write
<% if @config[:slapd_type] == 'provider' -%>
        by dn="<%= @config[:syncrepl_cn] %>,<%= @config[:basedn] %>" read
<% end -%>
        by * read
